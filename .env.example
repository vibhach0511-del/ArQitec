# Quantum AI Hackathon - API key template (Drop 4, steps 7-9)
# Copy this file to `.env` and fill in real values from each provider.
# These require manual web signup; they cannot be created automatically.

# Step 7: IBM Quantum (https://quantum.ibm.com -> Account -> API Token)
# After setting, register it once with:
#   QiskitRuntimeService.save_account(channel="ibm_quantum", token=IBM_QUANTUM_TOKEN)
IBM_QUANTUM_TOKEN=

# Step 8: Alpaca paper trading (https://alpaca.markets -> Paper Trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Step 9: Polygon.io (https://polygon.io -> free signup -> API key)
POLYGON_API_KEY=

# Optional: LLM provider for Track 4 agentic system (Drop 3)
OPENAI_API_KEY=
