# Quantum AI Hackathon - API key template (Drop 4, steps 7-9)
# Copy this file to `.env` and fill in real values from each provider.
# These require manual web signup; they cannot be created automatically.

# Step 6: Materials Project (https://materialsproject.org -> API key on dashboard)
MP_API_KEY=

# Step 7: XpyQ Cloud
# Dashboard: https://xpyq.vercel.app/functions  (invite-only email sign-in)
# Backend API (Bearer token): https://xpyq-lib-production.up.railway.app
XPYQ_EMAIL=sachin.news@gmail.com
XPYQ_API_KEY=
XPYQ_API_BASE=https://xpyq-lib-production.up.railway.app
XPYQ_UI_BASE=https://xpyq.vercel.app/functions

# Step 8: IBM Quantum (https://quantum.cloud.ibm.com -> API Token)
# Register once per machine (see https://quantum.cloud.ibm.com/docs/en/guides/hello-world):
#   from qiskit_ibm_runtime import QiskitRuntimeService
#   QiskitRuntimeService.save_account(token=IBM_QUANTUM_TOKEN)
IBM_QUANTUM_TOKEN=

# Step 9: Alpaca paper trading (https://alpaca.markets -> Paper Trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Step 10: Polygon.io (https://polygon.io -> free signup -> API key)
POLYGON_API_KEY=

# Optional: LLM provider for Track 4 agentic system (Drop 3)
OPENAI_API_KEY=
